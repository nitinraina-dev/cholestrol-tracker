{
  "expo": {
    "name": "cholesterol-tracker",
    "slug": "cholesterol-tracker",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A2E",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.nitinraina.cholesteroltracker",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_DOCUMENTS"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Cholesterol Tracker to access your photos to analyze food and upload lab reports.",
          "cameraPermission": "Allow Cholesterol Tracker to access the camera to scan your meals."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      ["expo-notifications", { "icon": "./assets/icon.png", "color": "#6C63FF" }],
      "react-native-edge-to-edge",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResources": true
          }
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/881d776d-69de-4dde-aeb6-fcfb1c5c4fed"
    },
    "extra": {
      "eas": {
        "projectId": "881d776d-69de-4dde-aeb6-fcfb1c5c4fed"
      }
    }
  }
}
